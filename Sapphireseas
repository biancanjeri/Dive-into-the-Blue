<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dive into the Sea | @Sapphire Seas</title>
<link rel="icon" href="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/72x72/1f40b.png">

<style>
/* --- THEME & AESTHETIC --- */
html { scroll-behavior: smooth; }
body {
  margin:0; font-family:"Trebuchet MS", sans-serif;
  background: linear-gradient(rgba(2, 31, 63, 0.75), rgba(2, 31, 63, 0.75)), 
              url('https://images.unsplash.com/photo-1546026423-cc4642628d2b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
  background-attachment: fixed; background-size: cover; background-position: center;
  color: white; overflow-x: hidden; font-size: 20px;
}

h1 { font-size: clamp(40px, 8vw, 85px); text-shadow: 0 0 20px #48cae4; text-align: center; }
h2 { font-size: 50px; color: #caf0f8; text-align: center; margin-top: 50px; text-shadow: 2px 2px 10px #000; }

/* --- GLOWING BUTTONS --- */
.mission-btn, button, .magic-bubble {
  padding: 20px 50px; font-size: 25px; border-radius: 50px; 
  background: #fff; color: #0077b6; font-weight: bold; 
  cursor: pointer; border: 3px solid #48cae4; 
  box-shadow: 0 0 15px #48cae4; transition: 0.3s;
  animation: pulseGlow 2s infinite;
}
@keyframes pulseGlow {
  0% { box-shadow: 0 0 10px #48cae4; transform: scale(1); }
  50% { box-shadow: 0 0 25px #fff; transform: scale(1.05); }
  100% { box-shadow: 0 0 10px #48cae4; transform: scale(1); }
}

/* --- NAVIGATION --- */
nav {
  position: fixed; top: 0; width: 100%; background: rgba(0, 8, 20, 0.8);
  backdrop-filter: blur(15px); display: flex; justify-content: center; flex-wrap: wrap; gap: 15px; padding: 15px; z-index: 1000;
}
nav a { color: #fff; text-decoration: none; font-weight: bold; font-size: 16px; }

/* --- SHORELINE --- */
#welcome { 
    height: 100vh; background: linear-gradient(to bottom, #fefae0 0%, rgba(162, 210, 255, 0.8) 100%); 
    display: flex; flex-direction: column; justify-content: center; align-items: center; color: #0077b6; position: relative;
}
.waves { width: 100%; height: 80px; position: absolute; bottom: 0; background: url('https://raw.githubusercontent.com/davidhckh/ocean-waves/master/wave.png'); background-size: 1000px 80px; animation: wave 10s linear infinite; }
@keyframes wave { 0% { background-position-x: 0; } 100% { background-position-x: 1000px; } }

/* --- POPPABLE BUBBLES --- */
.bubble {
  position: fixed; background: rgba(255,255,255,0.4); border: 2px solid white;
  border-radius: 50%; cursor: pointer; z-index: 2000; animation: rise 8s infinite linear;
}
@keyframes rise { 0% { transform: translateY(110vh); opacity: 0; } 10% { opacity: 1; } 100% { transform: translateY(-20vh); } }

/* --- DATA CARDS --- */
section { padding: 80px 20px; max-width: 1100px; margin: 0 auto; position: relative; z-index: 10; }
.card { background: rgba(0, 8, 20, 0.85); backdrop-filter: blur(10px); border: 2px solid #48cae4; border-radius: 30px; padding: 40px; margin-bottom: 30px; }
.stat-box { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin: 20px 0; }
.stat { background: rgba(255,255,255,0.1); padding: 20px; border-radius: 20px; text-align: center; border: 1px solid #48cae4; }
.stat h3 { font-size: 40px; margin: 0; color: #ff4d6d; }

/* --- TEAM --- */
.team-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
.team-member { background: rgba(255,255,255,0.1); padding: 20px; border-radius: 20px; border: 1px solid #fff; }

/* --- FLASHCARDS --- */
.animals-container { display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; }
.flip-card { width: 230px; height: 320px; perspective: 1000px; }
.flip-card-inner { position: relative; width: 100%; height: 100%; transition: transform 0.6s; transform-style: preserve-3d; cursor: pointer; }
.flip-card.flipped .flip-card-inner { transform: rotateY(180deg); }
.flip-card-front, .flip-card-back { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; border-radius: 20px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; }
.flip-card-front { background: rgba(0, 119, 182, 0.8); font-size: 80px; border: 2px solid white; }
.flip-card-back { background: #001219; transform: rotateY(180deg); font-size: 16px; border: 2px solid #48cae4; }

/* --- GAME CENTER STYLES --- */
.game-card { background: rgba(0, 18, 25, 0.9); border: 3px dashed #48cae4; border-radius: 30px; padding: 30px; margin-top: 30px; text-align: center; }
.game-screen { width: 100%; height: 200px; background: #000; border-radius: 20px; position: relative; overflow: hidden; margin: 20px 0; }
.player-turtle { font-size: 40px; position: absolute; bottom: 10px; left: 50%; transform: translateX(-50%); transition: 0.2s; }
.falling-shark { font-size: 40px; position: absolute; top: -50px; }

/* --- FINALE --- */
.finale { text-align: center; padding: 100px 20px; background: rgba(0,0,0,0.7); border-radius: 50px; margin-top: 50px; }
.trash-vortex { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 50px; pointer-events: none; z-index: 3000; opacity: 0; }
.suck-animation { animation: vortexSuck 2s forwards ease-in; }
@keyframes vortexSuck { 0% { transform: translate(-50%, -50%) scale(1) rotate(0deg); opacity: 1; } 100% { transform: translate(-50%, -100vh) scale(0) rotate(720deg); opacity: 0; } }

</style>
</head>
<body>

<nav>
  <a href="#welcome">Shore</a>
  <a href="#suffering">The Crisis</a>
  <a href="#help">Action Plan</a>
  <a href="#team">The Squad</a>
  <a href="#flashcards">Locals</a>
  <a href="#games">Games</a>
  <a href="#thank-you">Final Pop</a>
</nav>

<section id="welcome">
  <h1>DIVE INTO THE SEA</h1>
  <p style="font-size: 28px; font-weight: bold; color: #0077b6;">@Sapphire Seas</p>
  <button class="mission-btn" onclick="document.querySelector('#suffering').scrollIntoView()">DIVE INTO THE DATA 🤿</button>
  <div class="waves"></div>
</section>

<section id="suffering">
  <h2>The Ocean is Suffering</h2>
  <div class="card">
    <p>Our blue planet is facing an unprecedented crisis. Here are the facts our team discovered:</p>
    <div class="stat-box">
      <div class="stat"><h3>90%</h3><p>Of big fish populations are gone since 1950.</p></div>
      <div class="stat"><h3>8.8M</h3><p>Tons of plastic enter the sea every year.</p></div>
      <div class="stat"><h3>50%</h3><p>Of the world's coral reefs have been lost.</p></div>
    </div>
    <p><b>Global Warming:</b> The ocean absorbs 90% of the Earth's heat. This leads to "Coral Bleaching." Without reefs, 25% of all marine life loses its home!</p>
  </div>
</section>

<section id="help">
  <h2>Sapphire Seas Action Plan</h2>
  <div class="card" style="border-color: #69f0ae;">
    <h3>How YOU Can Help</h3>
    <ul style="line-height: 1.8;">
      <li>✅ <b>Zero Plastic:</b> Plastic lasts 450 years. Use reusable bags and bottles!</li>
      <li>✅ <b>Reduce Carbon:</b> Turn off lights. High CO2 levels melt the shells of crabs and oysters.</li>
      <li>✅ <b>Safe Washing:</b> Synthetic clothes leak microplastics. Use a filter in your laundry!</li>
      <li>✅ <b>Spread the Word:</b> Education is our best weapon. Share #SapphireSeas!</li>
    </ul>
  </div>
</section>

<section id="team">
  <h2>Meet the Squad @Sapphire Seas</h2>
  <div class="team-grid">
    <div class="team-member"><h4>Wambui</h4><p>"Is an amazing opportunity to learn about marine life and is so refreshing to know that our school has interest in saving the animals!"</p></div>
    <div class="team-member"><h4>Bianca</h4><p>"I love the ocean and it is always dirty so knowing we can lend a helping hand is amazinggg!"</p></div>
    <div class="team-member"><h4>Scarlett</h4><p>"I believe every bubble counts! If we all do a little, the sea can finally breathe again."</p></div>
    <div class="team-member"><h4>Jade</h4><p>"The sea is my happy place. Sapphire Seas is about protecting that happiness."</p></div>
    <div class="team-member"><h4>Telsy</h4><p>"Let's turn the tide together. It's not too late!"</p></div>
  </div>
</section>

<section id="flashcards">
  <h2>Meet the Locals</h2>
  <div class="animals-container">
    <div class="flip-card" onclick="this.classList.toggle('flipped')"><div class="flip-card-inner"><div class="flip-card-front">🐢</div><div class="flip-card-back"><h3>Sea Turtle</h3><p>52% of turtles have eaten plastic. Let's keep bags out of the water!</p></div></div></div>
    <div class="flip-card" onclick="this.classList.toggle('flipped')"><div class="flip-card-inner"><div class="flip-card-front">🦈</div><div class="flip-card-back"><h3>Great White</h3><p>They are apex predators that keep the ocean healthy and in balance.</p></div></div></div>
    <div class="flip-card" onclick="this.classList.toggle('flipped')"><div class="flip-card-inner"><div class="flip-card-front">🐙</div><div class="flip-card-back"><h3>Octopus</h3><p>They have 3 hearts and 9 brains. Masters of intelligence!</p></div></div></div>
  </div>
</section>

<section id="games">
  <h2>🎮 Sapphire Game Center</h2>

  <div class="game-card">
    <h3>1. Shark Dodge</h3>
    <p>Move the turtle with your mouse/finger to avoid the sharks!</p>
    <div class="game-screen" id="sharkGame">
      <div id="turtlePlayer" class="player-turtle">🐢</div>
    </div>
    <button onclick="startSharkGame()">Start Game</button>
  </div>

  <div class="game-card">
    <h3>2. Pearl Finder</h3>
    <p>Click the shells to find the hidden pearl! 💎</p>
    <div id="pearlGrid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; padding: 20px;">
        <span style="font-size:40px; cursor:pointer;" onclick="checkPearl(this)">🐚</span>
        <span style="font-size:40px; cursor:pointer;" onclick="checkPearl(this)">🐚</span>
        <span style="font-size:40px; cursor:pointer;" onclick="checkPearl(this)">🐚</span>
    </div>
    <button onclick="resetPearls()">Hide Pearl</button>
  </div>
</section>

<section id="thank-you" class="finale">
  <h2>Thank You For Diving With Us!</h2>
  <div class="magic-bubble" id="magicBubble" onclick="cleanOcean()">
    POP ME TO<br>SAVE THE SEA
  </div>
  <div id="vortexTrash" class="trash-vortex">🥤 🛍️ 🍼 🥡 📦</div>
  <h1 style="color: #48cae4; margin-top: 50px;">#SAPPHIRESEAS</h1>
</section>

<script>
// --- EXACT BUBBLES ---
function createBubble() {
  const b = document.createElement("div");
  b.className = "bubble";
  let size = Math.random() * 45 + 15;
  b.style.width = size + "px"; b.style.height = size + "px";
  b.style.left = Math.random() * 95 + "vw"; b.style.bottom = "-50px";
  b.style.animationDuration = (Math.random() * 4 + 4) + "s";
  b.onclick = function() { this.style.transform = "scale(0)"; setTimeout(() => this.remove(), 100); };
  document.body.appendChild(b);
}
setInterval(createBubble, 400);

// --- EXACT CLEANUP ---
function cleanOcean() {
    const bubble = document.getElementById('magicBubble');
    const trash = document.getElementById('vortexTrash');
    bubble.innerHTML = "✨ CLEANED ✨";
    bubble.style.background = "#69f0ae";
    trash.classList.add('suck-animation');
    setTimeout(() => { alert("Success! @Sapphire Seas has cleared the trash! 🌊💎"); }, 1500);
}

// --- NEW GAME 1: SHARK DODGE ---
function startSharkGame() {
    const screen = document.getElementById('sharkGame');
    const turtle = document.getElementById('turtlePlayer');
    
    screen.onmousemove = (e) => {
        let rect = screen.getBoundingClientRect();
        let x = e.clientX - rect.left;
        turtle.style.left = x + 'px';
    };

    let shark = document.createElement('div');
    shark.className = 'falling-shark';
    shark.innerHTML = '🦈';
    shark.style.left = Math.random() * 90 + '%';
    screen.appendChild(shark);

    let pos = -50;
    let anim = setInterval(() => {
        pos += 5;
        shark.style.top = pos + 'px';
        if (pos > 200) {
            clearInterval(anim);
            shark.remove();
            startSharkGame(); // Loop it
        }
    }, 30);
}

// --- NEW GAME 2: PEARL FINDER ---
let hasPearl = Math.floor(Math.random() * 3);
function checkPearl(el) {
    let shells = document.querySelectorAll('#pearlGrid span');
    let index = Array.from(shells).indexOf(el);
    if(index === hasPearl) {
        el.innerHTML = "💎";
        alert("You found the Sapphire Pearl!");
    } else {
        el.innerHTML = "💨";
    }
}
function resetPearls() {
    let shells = document.querySelectorAll('#pearlGrid span');
    shells.forEach(s => s.innerHTML = "🐚");
    hasPearl = Math.floor(Math.random() * 3);
}
</script>
</body>
</html>
